# ── AI (optional) ───────────────────────────────────────────────────────────
# Required only for cover letter drafting (Phase 9). App runs fully without it.
ANTHROPIC_API_KEY=sk-ant-...

# ── Profile ──────────────────────────────────────────────────────────────────
# Override profile symlink — useful on Windows where ln -s may not work.
# ACTIVE_PROFILE_PATH=profiles/me

# Optional: custom DB path (default: db/jobs.db)
# DB_PATH=db/jobs.db

# ── Greenhouse ────────────────────────────────────────────────────────────────
# Comma-separated list of company board slugs to scrape.
# Find a slug at: https://boards.greenhouse.io/<slug>/jobs
GREENHOUSE_COMPANIES=vercel,cloudflare,stripe,linear,anthropic

# ── JobSpy (Indeed, LinkedIn, ZipRecruiter, Glassdoor) ───────────────────────
JOBSPY_SEARCH_TERM=backend engineer python
JOBSPY_LOCATION=United States
JOBSPY_HOURS_OLD=72
JOBSPY_RESULTS_WANTED=50

# ── DB maintenance ────────────────────────────────────────────────────────────
# Jobs older than this (days) are deleted after each scrape if not tracked.
JOB_TTL_DAYS=30
# Jobs scored below this are deleted after each scrape if not tracked.
SCORE_FLOOR=0.3

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
