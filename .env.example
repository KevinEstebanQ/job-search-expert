# Required
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override profile directory (useful on Windows where symlinks may not work)
# ACTIVE_PROFILE_PATH=profiles/me

# Optional: custom DB path (default: db/jobs.db)
# DB_PATH=db/jobs.db

# JobSpy scraper config (used by Indeed, LinkedIn, ZipRecruiter, Glassdoor adapter)
JOBSPY_SEARCH_TERM=backend engineer python
JOBSPY_LOCATION=United States
JOBSPY_HOURS_OLD=72
JOBSPY_RESULTS_WANTED=50

# Logging
LOG_LEVEL=INFO
